{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint:fix --filter=...{STAGED} 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/PreToolUse/validate-command.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/PreToolUse/ask-user-to-review-commands.sh"
          }
        ]
      }
    ]
  }
}
