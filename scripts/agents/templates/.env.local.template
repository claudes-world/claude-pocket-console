# =============================================================================
# CLAUDE POCKET CONSOLE - AGENT ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# This template provides environment variables for agent-specific workspaces.
# Copy this file to your agent workspace and rename to .env.local
# Replace all {{PLACEHOLDER}} values with actual configuration.
# =============================================================================

# -----------------------------------------------------------------------------
# AGENT IDENTIFICATION
# -----------------------------------------------------------------------------
# Unique identifier for this agent instance
# Format: agent-{name}-{timestamp} or custom identifier
# Example: agent-terminal-20250702, agent-ui-main, agent-api-v2
AGENT_ID={{AGENT_ID}}

# Human-readable name for this agent
# Used in logs, UI, and GitHub integration
AGENT_NAME="{{AGENT_NAME}}"

# Agent role/specialization for task routing
# Options: terminal, ui, api, testing, deployment, research
AGENT_ROLE={{AGENT_ROLE}}

# -----------------------------------------------------------------------------
# PORT ALLOCATION
# -----------------------------------------------------------------------------
# Base port for this agent's services (increment by 100 for each agent)
# Agent 1: 3000-3099, Agent 2: 3100-3199, etc.
DEV_PORT_BASE={{DEV_PORT_BASE}}

# Specific port assignments (calculated from base)
API_PORT={{API_PORT}}
WEBSOCKET_PORT={{WEBSOCKET_PORT}}
VITE_DEV_PORT={{VITE_DEV_PORT}}
STORYBOOK_PORT={{STORYBOOK_PORT}}

# Port range for dynamic allocation (Docker containers, etc.)
PORT_RANGE_START={{PORT_RANGE_START}}
PORT_RANGE_END={{PORT_RANGE_END}}

# -----------------------------------------------------------------------------
# DOCKER CONFIGURATION
# -----------------------------------------------------------------------------
# Container prefix for this agent's Docker resources
# Prevents conflicts between agent workspaces
DOCKER_CONTAINER_PREFIX={{DOCKER_CONTAINER_PREFIX}}

# Docker network for agent isolation
DOCKER_NETWORK_NAME={{DOCKER_NETWORK_NAME}}

# Docker compose project name (must be unique per agent)
COMPOSE_PROJECT_NAME={{COMPOSE_PROJECT_NAME}}

# Resource limits for agent containers
DOCKER_MEMORY_LIMIT={{DOCKER_MEMORY_LIMIT}}
DOCKER_CPU_LIMIT={{DOCKER_CPU_LIMIT}}

# Security settings for rootless containers
DOCKER_USER_UID={{DOCKER_USER_UID}}
DOCKER_USER_GID={{DOCKER_USER_GID}}

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Convex deployment URL for this agent
# Format: https://{{team}}-{{project}}-{{deployment}}.convex.cloud
CONVEX_URL={{CONVEX_URL}}

# Convex deployment key for API access
CONVEX_DEPLOY_KEY={{CONVEX_DEPLOY_KEY}}

# Database prefix for agent-specific data isolation
DB_TABLE_PREFIX={{DB_TABLE_PREFIX}}

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# GitHub OAuth configuration for agent workspace
GITHUB_CLIENT_ID={{GITHUB_CLIENT_ID}}
GITHUB_CLIENT_SECRET={{GITHUB_CLIENT_SECRET}}

# Session security
SESSION_SECRET={{SESSION_SECRET}}
JWT_SECRET={{JWT_SECRET}}

# API rate limiting per agent
RATE_LIMIT_REQUESTS_PER_MINUTE={{RATE_LIMIT_REQUESTS_PER_MINUTE}}
RATE_LIMIT_BURST_SIZE={{RATE_LIMIT_BURST_SIZE}}

# -----------------------------------------------------------------------------
# WORKSPACE PATHS
# -----------------------------------------------------------------------------
# Absolute path to this agent's workspace directory
AGENT_WORKSPACE_PATH={{AGENT_WORKSPACE_PATH}}

# Relative paths within workspace
AGENT_LOGS_DIR={{AGENT_LOGS_DIR}}
AGENT_TEMP_DIR={{AGENT_TEMP_DIR}}
AGENT_CONFIG_DIR={{AGENT_CONFIG_DIR}}

# Shared monorepo paths (typically don't change)
MONOREPO_ROOT={{MONOREPO_ROOT}}
APPS_DIR={{APPS_DIR}}
PACKAGES_DIR={{PACKAGES_DIR}}

# -----------------------------------------------------------------------------
# ENVIRONMENT SETTINGS
# -----------------------------------------------------------------------------
# Development environment flag
NODE_ENV={{NODE_ENV}}

# Agent development mode (enables extra logging, hot reload, etc.)
AGENT_DEV_MODE={{AGENT_DEV_MODE}}

# Log level for agent operations
# Options: error, warn, info, debug, trace
AGENT_LOG_LEVEL={{AGENT_LOG_LEVEL}}

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING={{ENABLE_PERFORMANCE_MONITORING}}

# -----------------------------------------------------------------------------
# GITHUB INTEGRATION
# -----------------------------------------------------------------------------
# Repository information for GitHub integration
GITHUB_OWNER={{GITHUB_OWNER}}
GITHUB_REPO={{GITHUB_REPO}}

# Issue assignment and labeling
GITHUB_ISSUE_LABELS={{GITHUB_ISSUE_LABELS}}
GITHUB_AUTO_ASSIGN={{GITHUB_AUTO_ASSIGN}}

# Personal access token for GitHub API
GITHUB_TOKEN={{GITHUB_TOKEN}}

# -----------------------------------------------------------------------------
# DEVELOPMENT TOOLS
# -----------------------------------------------------------------------------
# Enable/disable development features
ENABLE_HOT_RELOAD={{ENABLE_HOT_RELOAD}}
ENABLE_SOURCE_MAPS={{ENABLE_SOURCE_MAPS}}
ENABLE_TYPESCRIPT_INCREMENTAL={{ENABLE_TYPESCRIPT_INCREMENTAL}}

# Linting and formatting
ESLINT_CONFIG_PATH={{ESLINT_CONFIG_PATH}}
PRETTIER_CONFIG_PATH={{PRETTIER_CONFIG_PATH}}

# Testing configuration
TEST_TIMEOUT={{TEST_TIMEOUT}}
TEST_PARALLEL_WORKERS={{TEST_PARALLEL_WORKERS}}

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES
# -----------------------------------------------------------------------------
# Claude API configuration (if agent uses AI features)
ANTHROPIC_API_KEY={{ANTHROPIC_API_KEY}}
CLAUDE_MODEL={{CLAUDE_MODEL}}

# Terminal service configuration
TERMINAL_SESSION_TIMEOUT={{TERMINAL_SESSION_TIMEOUT}}
MAX_TERMINAL_SESSIONS={{MAX_TERMINAL_SESSIONS}}

# WebSocket configuration
WS_HEARTBEAT_INTERVAL={{WS_HEARTBEAT_INTERVAL}}
WS_MAX_CONNECTIONS={{WS_MAX_CONNECTIONS}}

# -----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# -----------------------------------------------------------------------------
# Health check endpoints
HEALTH_CHECK_PORT={{HEALTH_CHECK_PORT}}
HEALTH_CHECK_PATH={{HEALTH_CHECK_PATH}}

# Metrics collection
METRICS_ENABLED={{METRICS_ENABLED}}
METRICS_PORT={{METRICS_PORT}}
METRICS_PATH={{METRICS_PATH}}

# Performance tracing
TRACING_ENABLED={{TRACING_ENABLED}}
TRACING_SERVICE_NAME={{TRACING_SERVICE_NAME}}

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES={{ENABLE_EXPERIMENTAL_FEATURES}}

# Feature-specific flags
ENABLE_TERMINAL_SHARING={{ENABLE_TERMINAL_SHARING}}
ENABLE_REAL_TIME_COLLABORATION={{ENABLE_REAL_TIME_COLLABORATION}}
ENABLE_ADVANCED_DEBUGGING={{ENABLE_ADVANCED_DEBUGGING}}

# -----------------------------------------------------------------------------
# BACKUP & RECOVERY
# -----------------------------------------------------------------------------
# Backup configuration for agent data
BACKUP_ENABLED={{BACKUP_ENABLED}}
BACKUP_INTERVAL={{BACKUP_INTERVAL}}
BACKUP_RETENTION_DAYS={{BACKUP_RETENTION_DAYS}}

# Recovery settings
AUTO_RECOVERY_ENABLED={{AUTO_RECOVERY_ENABLED}}
MAX_RECOVERY_ATTEMPTS={{MAX_RECOVERY_ATTEMPTS}}

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
# 
# USAGE NOTES:
# 1. Copy this file to your agent workspace as .env.local
# 2. Replace all {{PLACEHOLDER}} values with actual configuration
# 3. Never commit .env.local files to version control
# 4. Use environment-specific overrides for production deployment
# 5. Validate configuration using the setup scripts
#
# SECURITY NOTES:
# - Keep secrets secure and use proper secret management
# - Use different credentials for each environment
# - Regularly rotate API keys and tokens
# - Monitor access logs for security issues
#
# =============================================================================